      "alert_channel": {
        "attrs": {
          "label": "Alert channel",
          "value": "#deployments"
        },
        "edges": {},
        "id": "alert_channel",
        "kind": "field",
        "slots": {}
      },
      "daily_digest": {
        "attrs": {
          "label": "Daily digest",
          "value": "09:00 local time"
        },
        "edges": {},
        "id": "daily_digest",
        "kind": "field",
        "slots": {}
      },
      "failure_alerts": {
        "attrs": {
          "label": "Failure alerts",
          "value": "Enabled"
        },
        "edges": {},
        "id": "failure_alerts",
        "kind": "field",
        "slots": {}
      },
      "notification_settings": {
        "attrs": {
          "title": "Deployment notification settings"
        },
        "edges": {},
        "id": "notification_settings",
        "kind": "app",
        "slots": {}
      },
      "settings_intro": {
        "attrs": {
          "description": "Choose where urgent failures and routine deployment updates are delivered.",
          "eyebrow": "Workspace preferences",
          "title": "Deployment notifications"
        },
        "edges": {},
