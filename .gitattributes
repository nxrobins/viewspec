* text=auto

# ViewSpec artifacts carry byte-exact hashes; keep text output stable across OS checkouts.
.gitattributes text eol=lf
.gitignore text eol=lf
*.css text eol=lf
*.dart text eol=lf
*.html text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.mjs text eol=lf
*.py text eol=lf
*.swift text eol=lf
*.toml text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.txt text eol=lf
*.xml text eol=lf
